# Application
APP_NAME=POS Backend
APP_ENV=development

# Web Server
PORT=4001

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=pos_db
DB_SSLMODE=disable

# Database Pool Configuration (for Supabase PgBouncer)
DB_POOL_IDLE=10
DB_POOL_MAX=10
DB_POOL_LIFETIME=300
DB_PGBOUNCER=true
DB_CONNECTION_LIMIT=5

# JWT
JWT_SECRET=your-very-secret-jwt-key
JWT_EXPIRATION=24

# Log
LOG_LEVEL=debug
LOG_FORMAT=json